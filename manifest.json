{
  "manifest_version": 3,
  "name": "极简划词翻译",
  "version": "1.0.0",
  "description": "极简轻量划词翻译，选中即翻译，无需登录无限制",
  "permissions": [
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["popup.css"],
      "run_at": "document_end"
    }
  ]
}
